{
  "version": 2,
  "builds": [
    {
      "src": "flask/restapi.py",
      "use": "@vercel/python"
    },
    {
      "src": "templates/**",
      "use": "@vercel/static"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    },
    {
      "src": "JS/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "flask/restapi.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}