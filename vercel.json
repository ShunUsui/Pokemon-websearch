{
  "version": 2,
  "builds": [
    {
      "src": "flask/restapi.py",
      "use": "@vercel/python"
    },
    {
      "src": "templates/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "static/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "JS/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "flask/restapi.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "static/$1"
    },
    {
      "src": "/JS/(.*)",
      "dest": "JS/$1"
    },
    {
      "src": "/(.*)",
      "dest": "templates/index.html"
    }
  ]
}